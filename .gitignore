# логи прогонов
logs/*
!logs/.gitkeep
# рабочий scratch агентов: пробы, оракулы гейта, локальные логи (остаются на диске как референс, в репо не нужны)
context/**/tmp/
context/logs/
# нативные git-worktree напарников (isolation:"worktree") — Claude Code кладёт их сюда; в репо не нужны
.claude/worktrees/
# бинарные тестовые артефакты рендеров (грузятся по запросу, не в репо системы)
renders/*.png
# рендеры concept-artist — бинарь регенерится из исходного .html через Edge, в репо не кладём
concept-art/*.png
# локальные настройки и секреты
.claude/settings.local.json
# маркер QA-гейта — локальный, создаётся game-lead вручную, не коммитится
.claude/QA_OK
*.key
*.keys.json
.env
# крупные/сырые материалы проекта (грузятся по запросу, не в репо системы)
*.docx
*.pdf
*.xlsx
